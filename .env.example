# ============================================================
#  .env.example — Template environment variables
#  Copy file ini ke .env dan isi dengan nilai asli.
#  JANGAN commit .env ke Git!
# ============================================================

# Supabase Project URL (dari Dashboard → Settings → API)
SUPABASE_URL=https://xxxxx.supabase.co

# Supabase Anon Key (public key, aman di frontend)
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# CATATAN:
# - GROQ_API_KEY TIDAK disimpan di sini!
#   Simpan sebagai SECRET di Supabase:
#     supabase secrets set GROQ_API_KEY=gsk_xxxxx
# - File .env juga sudah di-gitignore.
